# Copy this file to `.env` and fill in real values locally.
# DO NOT commit your real `.env` file.

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Optional: if you decide to plug an LLM later, set its provider key here.
# Rules-based classifier works without any LLM and is the default.
LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=